```
# Bitrix CMS specific ignores
local/templates/*/components/*/.gitignore
local/templates/*/assets/
local/templates/*/dist/
local/templates/*/build/
local/templates/*/node_modules/

# General build artifacts
*.log
*.tmp
*.swp
*.bak
*.cache

# Dependencies
node_modules/
vendor/
composer.lock

# Environment
.env
.env.local
.env.*

# Editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg-info/

# JavaScript specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build directories
dist/
build/
target/
```